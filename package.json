{
  "name": "vsc-credit-meter",
  "publisher": "aprii",
  "displayName": "Token Meter for Copilot",
  "description": "Visual Studio Code extension to monitor daily GitHub Copilot token usage",
  "version": "1.1.0",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/example/vsc-credit-meter.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotMeter.signIn",
        "title": "Sign In to GitHub for Copilot Meter"
      }
    ],
    "configuration": {
      "title": "Copilot Token Meter",
      "properties": {
        "copilotMeter.monthlyTokenLimit": {
          "type": "number",
          "default": 300,
          "description": "Total available premium requests/tokens per month (Default 300 for Copilot Pro)."
        },
        "copilotMeter.subscriptionStartDay": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 31,
          "description": "The day of the month your subscription resets (1-31)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0"
  }
}
